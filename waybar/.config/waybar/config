{
    // General settings
    "layer": "top",
    "output": "eDP-1",

    // Define modules to use
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["wireplumber", "cpu", "memory", "battery", "clock", "systemd-failed-units"],

    // Configure modules
    "sway/window": {
        "max-length": 100
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": " {volume}% ",
        "format-icons": {
            "default": ["", ""]
        },
    },
    "cpu": {
        "interval": 3,
        "format-alt": "{load}"
    },
    "memory": {
        "interval": 3,
        "format": "{used:0.2f} GiB",
        "format-alt": "{percentage}%",
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "clock": {
        "format": "{:%a %b %d %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    }
}
